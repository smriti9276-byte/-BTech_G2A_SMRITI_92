#include <stdio.h>

int main() {
    float celsius, fahrenheit;

    // Input temperature in centigrade
    printf("Enter temperature in Centigrade: ");
    scanf("%f", &celsius);

    // Convert to Fahrenheit
    fahrenheit = (celsius * 9/5) + 32;

    // Output result
    printf("Temperature in Fahrenheit = %.2f\n", fahrenheit);

    return 0;
}
